#include <zephyr/dt-bindings/input/input-event-codes.h>

/*
 * Two PMW3610 devices sharing one SPI bus (two chip-selects), to build-test
 * DESIGN.md Phase F's per-device settings keys ("<param>@<id>") for more
 * than one device in a single firmware image. `trackball` sets an explicit
 * `settings-id` (the recommended, human-readable path); `trackball2` omits
 * it, exercising the devicetree-path-hash fallback.
 *
 * tester_xiao's default kscan wires all of xiao_d 0..10 as key inputs, which
 * conflicts with the SPI/IRQ/CS pins used below (D4, D5, D6, D8, D9, D10).
 * Restrict kscan to D0-D3 and shrink the matrix transform to match.
 */
&kscan0 {
	input-gpios
		= <&xiao_d 0 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
		, <&xiao_d 1 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
		, <&xiao_d 2 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
		, <&xiao_d 3 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
		;
};

/*
 * RC(row, col) here must be the matrix-transform variant, but the keymap's
 * own includes (dt-bindings/zmk/keys.h -> modifiers.h) redefine RC(keycode)
 * as a single-argument modifier helper. Since all devicetree
 * sources/overlays share one preprocessor pass, force the matrix-transform
 * definition back for this file.
 */
#undef RC
#include <dt-bindings/zmk/matrix_transform.h>

&transform0 {
	columns = <4>;
	map = <
	RC(0,0)  RC(0,1)  RC(0,2)  RC(0,3)
	>;
};

&pinctrl {
	spi0_default: spi0_default {
		group1 {
			psels = <NRF_PSEL(SPIM_SCK, 0, 5)>, <NRF_PSEL(SPIM_MOSI, 1, 13)>, <NRF_PSEL(SPIM_MISO, 1, 13)>;
		};
	};
	spi0_sleep: spi0_sleep {
		group1 {
			psels = <NRF_PSEL(SPIM_SCK, 0, 5)>, <NRF_PSEL(SPIM_MOSI, 1, 13)>, <NRF_PSEL(SPIM_MISO, 1, 13)>;
			low-power-enable;
		};
	};
};

&spi0 {
	compatible = "nordic,nrf-spim";
	status = "okay";
	pinctrl-0 = <&spi0_default>;
	pinctrl-1 = <&spi0_sleep>;
	pinctrl-names = "default", "sleep";
	cs-gpios = <&xiao_d 10 GPIO_ACTIVE_LOW>, <&xiao_d 6 GPIO_ACTIVE_LOW>;

	trackball: trackball@0 {
		status = "okay";
		compatible = "cormoran,pmw3610";
		reg = <0>;
		spi-max-frequency = <2000000>;
		irq-gpios = <&xiao_d 9 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
		evt-type = <INPUT_EV_REL>;
		x-input-code = <INPUT_REL_X>;
		y-input-code = <INPUT_REL_Y>;
		settings-id = "primary";
	};

	trackball2: trackball2@1 {
		status = "okay";
		compatible = "cormoran,pmw3610";
		reg = <1>;
		spi-max-frequency = <2000000>;
		irq-gpios = <&xiao_d 4 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
		evt-type = <INPUT_EV_REL>;
		x-input-code = <INPUT_REL_X>;
		y-input-code = <INPUT_REL_Y>;
		/* No settings-id: exercises the devicetree-path-hash fallback. */
	};
};

/ {
	trackball_listener {
		compatible = "zmk,input-listener";
		device = <&trackball>;
	};
	trackball2_listener {
		compatible = "zmk,input-listener";
		device = <&trackball2>;
	};
};
